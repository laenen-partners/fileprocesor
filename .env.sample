# Gotenberg — document-to-PDF conversion (empty = log stub)
GOTENBERG_URL=http://localhost:3100

# Docling — PDF-to-markdown extraction (empty = log stub)
DOCLING_URL=http://localhost:5001

# pdf2img — PDF thumbnail generation (empty = log stub)
PDF2IMG_URL=http://localhost:3101

# ClamAV — antivirus scanning (empty = disabled, logs warning)
CLAMAV_ADDRESS=localhost:3310

# Bucket allowlist (empty = all buckets allowed)
# ALLOWED_BUCKETS=my-bucket,other-bucket

# Max file size for downloads (default 256MB)
# MAX_FILE_SIZE_BYTES=268435456

# --- For Process workflow tests (consumer-managed, not part of Config) ---
# DBOS_DATABASE_URL=postgres://postgres:postgres@localhost:5434/fileprocessor?sslmode=disable
# ENTITY_STORE_URL=http://localhost:3002
